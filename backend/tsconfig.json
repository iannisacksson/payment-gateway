{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "types": [],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "baseUrl": "./",
    "outDir": "./dist",
    "paths": {
      "@payment-gateway/domain": ["src/domain"],
      "@payment-gateway/domain/*": ["src/domain/*"],
      "@payment-gateway/infra": ["src/infra"],
      "@payment-gateway/infra/*": ["src/infra/*"],
      "@payment-gateway/application": ["src/application"],
      "@payment-gateway/application/*": ["src/application/*"],
      "@payment-gateway/shared": ["src/shared"],
      "@payment-gateway/shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
